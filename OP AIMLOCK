-- Get target part based on mode
local function getTargetPart(char)
    if targetMode == "Head" then
        return char:FindFirstChild("Head")
    else
        return char:FindFirstChild("HumanoidRootPart") or char:FindFirstChild("Torso") or char:FindFirstChild("UpperTorso")
    end
end

-- Find closest player to camera look direction
local function getClosestPlayer()
    local bestPlayer = nil
    local bestDot = -1

    local cameraPos = Camera.CFrame.Position
    local cameraDir = Camera.CFrame.LookVector

    for _, player in ipairs(Players:GetPlayers()) do
        if player == LocalPlayer then continue end
        local char = player.Character
        if not char then continue end
        local part = getTargetPart(char)
        local humanoid = char:FindFirstChildOfClass("Humanoid")
        if not part or not humanoid or humanoid.Health <= 0 then continue end

        local toTarget = (part.Position - cameraPos).Unit
        local dot = cameraDir:Dot(toTarget)
        if dot > bestDot then
            bestDot = dot
            bestPlayer = player
        end
    end

    return bestPlayer
end

-- Aimlock loop
local function startAimlock()
    connection = RunService.RenderStepped:Connect(function()
        if not isRightMouseHeld then
            lockedTarget = nil
            return
        end

        if not lockedTarget then
            lockedTarget = getClosestPlayer()
        end

        if lockedTarget then
            local char = lockedTarget.Character
            if not char then lockedTarget = nil return end
            local part = getTargetPart(char)
            local humanoid = char:FindFirstChildOfClass("Humanoid")
            if not part or not humanoid or humanoid.Health <= 0 then
                lockedTarget = nil
                return
            end
            Camera.CFrame = CFrame.new(Camera.CFrame.Position, part.Position)
        end
    end)
end

local function stopAimlock()
    if connection then
        connection:Disconnect()
        connection = nil
    end
    lockedTarget = nil
end

-- Shared aimlock toggle
local function toggleAimlock()
    aimlockEnabled = not aimlockEnabled

    if aimlockEnabled then
        ToggleBtn.BackgroundColor3 = Color3.fromRGB(50, 180, 50)
        startAimlock()
        sendNotification("Aimlock", "Aimlock enabled")
    else
        ToggleBtn.BackgroundColor3 = Color3.fromRGB(200, 50, 50)
        isRightMouseHeld = false
        stopAimlock()
        sendNotification("Aimlock", "Aimlock off")
    end
end

-- Shared mode toggle
local function toggleMode()
    if targetMode == "Torso" then
        targetMode = "Head"
        ModeLabel.Text = "Head"
        ModeLabel.TextColor3 = Color3.fromRGB(255, 100, 100)
        ModeBtn.BackgroundColor3 = Color3.fromRGB(200, 80, 80)
        sendNotification("Aimlock", "Mode switched to Head")
    else
        targetMode = "Torso"
        ModeLabel.Text = "Torso"
        ModeLabel.TextColor3 = Color3.fromRGB(100, 200, 255)
        ModeBtn.BackgroundColor3 = Color3.fromRGB(80, 80, 200)
        sendNotification("Aimlock", "Mode switched to Torso")
    end
    lockedTarget = nil -- reset lock when switching
end

-- Button clicks
ToggleBtn.MouseButton1Click:Connect(toggleAimlock)
ModeBtn.MouseButton1Click:Connect(toggleMode)

-- Keyboard input
UserInputService.InputBegan:Connect(function(input, gameProcessed)
    if gameProcessed then return end

    if input.KeyCode == Enum.KeyCode.Minus then
        toggleAimlock()
    end

    if input.KeyCode == Enum.KeyCode.Equals then -- "=" key is "+" without shift
        toggleMode()
    end

    if input.UserInputType == Enum.UserInputType.MouseButton2 and aimlockEnabled then
        isRightMouseHeld = true
    end
end)

UserInputService.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton2 then
        isRightMouseHeld = false
        lockedTarget = nil
    end
end)
